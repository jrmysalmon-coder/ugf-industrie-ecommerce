{
      "name": "ugf-industrie-ecommerce",
      "version": "0.1.0",
      "private": true,
      "description": "Plateforme e-commerce B2B pour UGF Industrie",
      "scripts": {
              "dev": "next dev",
              "dev:api": "nodemon backend/server.js",
              "dev:all": "concurrently \"npm run dev\" \"npm run dev:api\"",
              "build": "next build",
              "start": "next start",
              "start:api": "NODE_ENV=production node backend/server.js",
              "lint": "next lint",
              "lint:fix": "next lint --fix",
              "type-check": "tsc --noEmit",
              "db:types": "supabase gen types typescript --project-id $SUPABASE_PROJECT_ID > src/types/database.ts",
              "db:migrate": "supabase db push",
              "db:seed": "node scripts/seed.js",
              "test": "jest",
              "test:watch": "jest --watch",
              "test:coverage": "jest --coverage"
      },
      "dependencies": {
              "@stripe/stripe-js": "^4.0.0",
              "@supabase/ssr": "^0.5.0",
              "@supabase/supabase-js": "^2.45.0",
              "compression": "^1.7.4",
              "cors": "^2.8.5",
              "dotenv": "^16.4.5",
              "express": "^4.19.2",
              "express-rate-limit": "^7.3.1",
              "helmet": "^7.1.0",
              "morgan": "^1.10.0",
              "next": "14.2.5",
              "react": "^18",
              "react-dom": "^18",
              "stripe": "^16.0.0",
              "zod": "^3.23.8"
      },
      "devDependencies": {
              "@types/compression": "^1.7.5",
              "@types/cors": "^2.8.17",
              "@types/express": "^4.17.21",
              "@types/morgan": "^1.9.9",
              "@types/node": "^20",
              "@types/react": "^18",
              "@types/react-dom": "^18",
              "concurrently": "^8.2.2",
              "eslint": "^8",
              "eslint-config-next": "14.2.5",
              "jest": "^29.7.0",
              "nodemon": "^3.1.4",
              "postcss": "^8",
              "tailwindcss": "^3.4.1",
              "typescript": "^5"
      },
      "engines": {
              "node": ">=20.0.0",
              "npm": ">=10.0.0"
      }
}
